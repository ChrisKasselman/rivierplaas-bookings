<%- include('layout-top', { title: 'Dashboard', page: 'dashboard', user }) %>
<div class="page-header">
  <h1 class="page-title">Dashboard</h1>
  <a href="/bookings/new" class="btn btn-primary">+ New booking</a>
</div>

<h2 class="section-title">Room bookings</h2>
<div class="stats-grid">
  <a href="/dashboard/rooms/all" class="stat-card stat-link">
    <div class="stat-label">Total bookings</div>
    <div class="stat-value"><%= stats.total %></div>
  </a>
  <a href="/dashboard/rooms/upcoming" class="stat-card stat-link">
    <div class="stat-label">Upcoming stays</div>
    <div class="stat-value blue"><%= stats.upcoming %></div>
  </a>
  <a href="/dashboard/rooms/fully_paid" class="stat-card stat-link">
    <div class="stat-label">Fully paid</div>
    <div class="stat-value green"><%= stats.paid %></div>
  </a>
  <a href="/dashboard/rooms/deposit" class="stat-card stat-link">
    <div class="stat-label">Deposit only</div>
    <div class="stat-value amber"><%= stats.deposit %></div>
  </a>
  <a href="/dashboard/rooms/unpaid" class="stat-card stat-link">
    <div class="stat-label">Unpaid</div>
    <div class="stat-value red"><%= stats.unpaid %></div>
  </a>
  <a href="/dashboard/rooms/no_payment" class="stat-card stat-link">
    <div class="stat-label">No payment</div>
    <div class="stat-value purple"><%= stats.nopayment %></div>
  </a>
  <a href="/dashboard/rooms/cancelled" class="stat-card stat-link">
    <div class="stat-label">Cancelled</div>
    <div class="stat-value grey"><%= stats.cancelled %></div>
  </a>
</div>

<h2 class="section-title" style="margin-top:2rem">Wedding bookings</h2>
<div class="stats-grid">
  <a href="/dashboard/weddings/all" class="stat-card stat-link">
    <div class="stat-label">Total weddings</div>
    <div class="stat-value"><%= stats.wTotal %></div>
  </a>
  <a href="/dashboard/weddings/upcoming" class="stat-card stat-link">
    <div class="stat-label">Upcoming weddings</div>
    <div class="stat-value blue"><%= stats.wUpcoming %></div>
  </a>
  <a href="/dashboard/weddings/fully_paid" class="stat-card stat-link">
    <div class="stat-label">Fully paid</div>
    <div class="stat-value green"><%= stats.wPaid %></div>
  </a>
  <a href="/dashboard/weddings/deposit" class="stat-card stat-link">
    <div class="stat-label">Deposit only</div>
    <div class="stat-value amber"><%= stats.wDeposit %></div>
  </a>
  <a href="/dashboard/weddings/unpaid" class="stat-card stat-link">
    <div class="stat-label">Unpaid</div>
    <div class="stat-value red"><%= stats.wUnpaid %></div>
  </a>
  <a href="/dashboard/weddings/no_payment" class="stat-card stat-link">
    <div class="stat-label">No payment</div>
    <div class="stat-value purple"><%= stats.wNopayment %></div>
  </a>
  <a href="/dashboard/weddings/cancelled" class="stat-card stat-link">
    <div class="stat-label">Cancelled</div>
    <div class="stat-value grey"><%= stats.wCancelled %></div>
  </a>
</div>

<div class="quick-links" style="margin-top:2rem">
  <a href="/bookings" class="quick-card">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
    <div>
      <div class="qc-title">Room bookings</div>
      <div class="qc-sub">Search, filter and manage</div>
    </div>
  </a>
  <a href="/weddings" class="quick-card">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21c-4-4-8-7.5-8-11a8 8 0 0 1 16 0c0 3.5-4 7-8 11z"/><circle cx="12" cy="10" r="2"/></svg>
    <div>
      <div class="qc-title">Wedding bookings</div>
      <div class="qc-sub">Manage wedding venue bookings</div>
    </div>
  </a>
  <a href="/rooms" class="quick-card">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 21V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14"/><path d="M3 21h18M9 21V12h6v9"/></svg>
    <div>
      <div class="qc-title">Room availability</div>
      <div class="qc-sub">Check rooms by date</div>
    </div>
  </a>
  <% if(user.role === 'manager') { %>
  <a href="/admin" class="quick-card">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2a5 5 0 1 0 0 10A5 5 0 0 0 12 2zM4 20a8 8 0 0 1 16 0"/></svg>
    <div>
      <div class="qc-title">Admin panel</div>
      <div class="qc-sub">Staff accounts &amp; reports</div>
    </div>
  </a>
  <a href="/export" class="quick-card">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    <div>
      <div class="qc-title">Export to CSV</div>
      <div class="qc-sub">Download all bookings</div>
    </div>
  </a>
  <% } %>
</div>
<%- include('layout-bottom') %>
