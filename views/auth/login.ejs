<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rivierplaas — Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-body">
  <div class="login-bg-logo">
    <img src="/images/logo.jpg" alt="">
  </div>
  <div class="login-wrap">
    <div class="login-card">
      <img src="/images/logo.jpg" alt="Rivierplaas" class="login-logo-img">
      <p class="login-sub">Ommidraai &amp; Inniebos venue bookings</p>
      <% if(error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/login">
        <div class="form-group">
          <label>Email address</label>
          <input type="email" name="email" placeholder="you@rivierplaas.co.za" required autofocus>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" placeholder="••••••••" required>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Sign in</button>
      </form>
      <p class="login-note">Contact your manager to reset your password</p>
    </div>
  </div>
</body>
</html>
