<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rivierplaas — <%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <div class="sidebar-logo">
        <img src="/images/logo.jpg" alt="Rivierplaas" class="sidebar-logo-img">
      </div>
      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item <%= page==='dashboard'?'active':'' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          Dashboard
        </a>
        <a href="/bookings" class="nav-item <%= page==='bookings'?'active':'' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          Room bookings
        </a>
        <a href="/bookings/new" class="nav-item <%= page==='new'?'active':'' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 8v8M8 12h8"/></svg>
          New room booking
        </a>
        <a href="/weddings" class="nav-item <%= page==='weddings'?'active':'' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21c-4-4-8-7.5-8-11a8 8 0 0 1 16 0c0 3.5-4 7-8 11z"/><circle cx="12" cy="10" r="2"/></svg>
          Wedding bookings
        </a>
        <a href="/rooms" class="nav-item <%= page==='rooms'?'active':'' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 21V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14"/><path d="M3 21h18M9 21V12h6v9"/></svg>
          Room availability
        </a>
        <% if(user.role === 'manager' || user.ta_access) { %>
        <a href="/attendance/records" class="nav-item <%= page==='attendance'?'active':'' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Time & Attendance
        </a>
        <% } %>
        <% if(user.role === 'manager') { %>
        <div class="nav-section">Manager</div>
        <a href="/attendance" class="nav-item <%= page==='attendance'?'active':'' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          T&A Management
        </a>
        <a href="/admin" class="nav-item <%= page==='admin'?'active':'' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2a5 5 0 1 0 0 10A5 5 0 0 0 12 2zM4 20a8 8 0 0 1 16 0"/></svg>
          Admin panel
        </a>
        <a href="/admin/audit" class="nav-item <%= page==='audit'?'active':'' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 12h6M9 16h6M9 8h6M5 3h14a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/></svg>
          Audit log
        </a>
        <a href="/export" class="nav-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Export CSV
        </a>
        <a href="/admin/backup" class="nav-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/><path d="M7 10l5 5 5-5"/></svg>
          Full backup (ZIP)
        </a>
        <% } %>
      </nav>
      <div class="sidebar-footer">
        <div class="user-info">
          <div class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
          <div>
            <div class="user-name"><%= user.name %></div>
            <div class="user-role"><%= user.role === 'manager' ? 'Manager' : 'Staff' %></div>
          </div>
        </div>
        <a href="/logout" class="logout-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </a>
      </div>
    </aside>
    <main class="main-content main-with-bg">
      <div class="main-bg-logo">
        <img src="/images/logo.jpg" alt="">
      </div>
