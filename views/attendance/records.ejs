<%- include('../layout-top', { title: 'Attendance Records', page: 'attendance', user }) %>
<div class="page-header">
  <h1 class="page-title">Attendance records</h1>
  <div style="display:flex;gap:0.5rem">
    <a href="/attendance" class="btn btn-ghost">← Employees</a>
    <a href="/attendance/reports" class="btn btn-secondary">📊 Reports</a>
    <a href="/attendance/export?from=<%= from %>&to=<%= to %>" class="btn btn-secondary">↓ Export CSV</a>
  </div>
</div>

<form method="GET" action="/attendance/records" class="filter-bar">
  <div style="display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center">
    <label style="font-size:0.85rem;color:#6b7280">From</label>
    <input type="date" name="from" value="<%= from %>" style="width:auto">
    <label style="font-size:0.85rem;color:#6b7280">To</label>
    <input type="date" name="to" value="<%= to %>" style="width:auto">
    <select name="employee_id">
      <option value="">All employees</option>
      <% employees.forEach(e => { %>
        <option value="<%= e.id %>" <%= employee_id == e.id ? 'selected' : '' %>><%= e.name %></option>
      <% }) %>
    </select>
    <button type="submit" class="btn btn-secondary">Filter</button>
  </div>
</form>

<div class="attendance-summary">
  <span><strong><%= records.length %></strong> records</span>
  <span>Total hours: <strong><%= totalHours %>h</strong></span>
</div>

<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr><th>Date</th><th>Employee</th><th>Clock in</th><th>Clock out</th><th>Hours</th></tr>
    </thead>
    <tbody>
      <% if(!records.length) { %>
        <tr><td colspan="5" class="empty-row">No records found for this period.</td></tr>
      <% } %>
      <% records.forEach(r => { %>
      <tr>
        <td><%= new Date(r.date).toLocaleDateString('en-ZA', {weekday:'short', year:'numeric', month:'short', day:'numeric'}) %></td>
        <td><strong><%= r.emp_name %></strong><% if(r.emp_phone) { %><div class="muted" style="font-size:0.78rem"><%= r.emp_phone %></div><% } %></td>
        <td><%= fmtTime(r.clock_in) %></td>
        <td><%= r.clock_out ? fmtTime(r.clock_out) : '<span class="badge badge-warning">Still in</span>' %></td>
        <td><% if(r.hours_worked) { %><strong><%= parseFloat(r.hours_worked).toFixed(2) %>h</strong><% } else { %><span class="muted">—</span><% } %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../layout-bottom') %>
