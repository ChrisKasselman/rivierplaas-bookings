<%- include('../layout-top', { title: title, page: 'dashboard', user }) %>
<div class="page-header">
  <h1 class="page-title"><%= title %></h1>
  <a href="/dashboard" class="btn btn-ghost">← Dashboard</a>
</div>

<div class="table-wrap">
  <% if(type === 'rooms') { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Guest</th>
        <th>Contact</th>
        <th>Venue</th>
        <th>Room</th>
        <th>Check-in</th>
        <th>Check-out</th>
        <th>Payment</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(rows.length === 0) { %>
      <tr><td colspan="8" class="empty-row">No bookings found.</td></tr>
      <% } %>
      <% rows.forEach(b => { %>
      <tr>
        <td><strong><%= b.firstname %> <%= b.surname %></strong></td>
        <td class="contact-cell">
          <span><%= b.email %></span>
          <span class="muted"><%= b.cell %></span>
        </td>
        <td><span class="badge badge-venue"><%= b.venue %></span></td>
        <td>Room <%= b.room %></td>
        <td><%= new Date(b.checkin).toLocaleDateString('en-ZA') %></td>
        <td><%= new Date(b.checkout).toLocaleDateString('en-ZA') %></td>
        <td>
          <% if(b.fully_paid) { %>
            <span class="badge badge-success">Fully paid</span>
          <% } else if(b.deposit_paid) { %>
            <span class="badge badge-warning">Deposit</span>
          <% } else { %>
            <span class="badge badge-danger">Unpaid</span>
          <% } %>
        </td>
        <td class="actions-cell">
          <a href="/bookings/<%= b.id %>/edit" class="btn btn-sm">Edit</a>
          <% if(user.role === 'manager') { %>
          <form method="POST" action="/bookings/<%= b.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this booking?')">
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Client</th>
        <th>Contact</th>
        <th>Venue</th>
        <th>Event date</th>
        <th>End date</th>
        <th>Guests</th>
        <th>Payment</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(rows.length === 0) { %>
      <tr><td colspan="8" class="empty-row">No wedding bookings found.</td></tr>
      <% } %>
      <% rows.forEach(w => { %>
      <tr>
        <td><strong><%= w.firstname %> <%= w.surname %></strong></td>
        <td class="contact-cell">
          <span><%= w.email %></span>
          <span class="muted"><%= w.cell %></span>
        </td>
        <td><span class="badge badge-wedding"><%= w.venue %></span></td>
        <td><%= new Date(w.event_date).toLocaleDateString('en-ZA') %></td>
        <td><%= new Date(w.event_end_date).toLocaleDateString('en-ZA') %></td>
        <td><span class="badge badge-guests"><%= w.guests %></span></td>
        <td>
          <% if(w.fully_paid) { %>
            <span class="badge badge-success">Fully paid</span>
          <% } else if(w.deposit_paid) { %>
            <span class="badge badge-warning">Deposit</span>
          <% } else { %>
            <span class="badge badge-danger">Unpaid</span>
          <% } %>
        </td>
        <td class="actions-cell">
          <a href="/weddings/<%= w.id %>/edit" class="btn btn-sm">Edit</a>
          <% if(user.role === 'manager') { %>
          <form method="POST" action="/weddings/<%= w.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this wedding booking?')">
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('../layout-bottom') %>
